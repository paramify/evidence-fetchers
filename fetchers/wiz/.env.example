# Wiz API Credentials
# ===================
# Get these from: Wiz UI → Settings → Service Accounts
# Required permissions: read:issues, create:reports, update:reports
WIZ_CLIENT_ID=your_wiz_client_id_here
WIZ_CLIENT_SECRET=your_wiz_client_secret_here
WIZ_AUTH_URL=https://auth.app.wiz.io/oauth/token

# Replace YOUR_TENANT with your Wiz tenant identifier (e.g., us17, eu1)
WIZ_API_ENDPOINT=https://api.YOUR_TENANT.app.wiz.io/graphql

# Paramify API Configuration
# ==========================
# Get base URL from your Paramify deployment
# Get token from: Paramify UI → Settings → API Tokens
#   Required permissions: View Issues, Write Issues, View Evidences, Write Evidences
# Get assessment ID from the URL when viewing your assessment:
#   https://app.paramify.com/assessment/{ASSESSMENT_ID}
PARAMIFY_API_BASE_URL=https://app.paramify.com/api/v0
PARAMIFY_API_TOKEN=your_paramify_api_token_here
PARAMIFY_ASSESSMENT_ID=your_assessment_uuid_here

# Delta Mode
# ==========
# Set to "true" after first successful run for incremental updates
# Set to "false" for full CSV upload every run
DELTA_MODE=false
